{
  "name": "agent-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:debug": "node --inspect --import tsx src/index.ts",
    "dev:debug-brk": "node --inspect-brk --import tsx src/index.ts",
    "dev:wecom:debug": "cross-env CHANNEL_MODE=wecom node --inspect --import tsx src/index.ts",
    "dev:wecom:debug-brk": "cross-env CHANNEL_MODE=wecom node --inspect-brk --import tsx src/index.ts",
    "dev:member-profile": "tsx src/dev/runMemberProfileQueryDemo.ts",
    "dev:intent-multi": "tsx src/dev/runIntentMultiTurnDemo.ts",
    "dev:chat": "tsx src/dev/runCliChat.ts",
    "dev:wecom": "cross-env CHANNEL_MODE=wecom tsx src/index.ts",
    "dev:wecom-http": "cross-env CHANNEL_MODE=wecom-http tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/openai": "^1.2.0",
    "@wecom/aibot-node-sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "mysql2": "^3.20.0",
    "nanoid": "^5.1.7",
    "oracledb": "^6.10.0",
    "wecom-webhook-sdk": "^1.0.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
